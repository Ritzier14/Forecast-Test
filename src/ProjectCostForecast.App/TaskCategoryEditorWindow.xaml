<Window x:Class="ProjectCostForecast.App.TaskCategoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ProjectCostForecast.App.Models"
        Title="Task and Category Editor"
        Width="1040"
        Height="720"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="RoundedActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D6E0EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,3" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,20,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                            <Border x:Name="ActiveUnderline"
                                    Height="3"
                                    Background="{TemplateBinding BorderBrush}"
                                    VerticalAlignment="Bottom"
                                    Visibility="Visible" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1E3A5F" />
                            </Trigger>
                            <Trigger Property="BorderBrush" Value="Transparent">
                                <Setter TargetName="ActiveUnderline" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE4EE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowHeight" Value="38" />
            <Setter Property="ColumnHeaderHeight" Value="44" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E7EDF5" />
            <Setter Property="VerticalGridLinesBrush" Value="#E7EDF5" />
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="BorderBrush" Value="#E7EDF5" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          Margin="10,0" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DDEBFF" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="BorderBrush" Value="#E7EDF5" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            SnapsToDevicePixels="True">
                                        <SelectiveScrollingGrid>
                                            <SelectiveScrollingGrid.ColumnDefinitions>
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="*" />
                                            </SelectiveScrollingGrid.ColumnDefinitions>
                                            <Border x:Name="SelectedIndicator"
                                                    Grid.Column="0"
                                                    Background="Transparent" />
                                            <DataGridCellsPresenter Grid.Column="1" />
                                        </SelectiveScrollingGrid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FBFF" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EEF5FF" />
                                            <Setter TargetName="SelectedIndicator" Property="Background" Value="#2563EB" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorTextColumnDisplayStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EditorTextColumnEditingStyle" TargetType="TextBox">
            <EventSetter Event="GotKeyboardFocus" Handler="EditorInlineTextBox_GotKeyboardFocus" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="EditorInlineTextBox_PreviewMouseLeftButtonDown" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="CaretBrush" Value="#2563EB" />
            <Setter Property="MinHeight" Value="30" />
        </Style>
    </Window.Resources>

    <Border Margin="18"
            Background="#F6F8FC"
            BorderBrush="#E5EAF3"
            BorderThickness="1"
            CornerRadius="24"
            Padding="26">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18" MouseLeftButtonDown="WindowHeader_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="42"
                            Height="42"
                            Background="#F5F8FF"
                            BorderBrush="#DCE6F7"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Text="TC"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Task and Category Editor"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="Project task codes, task names, categories, icons, and colours"
                                   FontSize="13"
                                   Foreground="#64748B" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Width="40"
                        Height="40"
                        Click="Cancel_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#374151"
                        FontSize="20"
                        Content="X"
                        ToolTip="Close" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,14">
                <Border Height="1"
                        Background="#DCE4EE"
                        VerticalAlignment="Bottom" />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="TaskCodesTabButton"
                            Content="Task Codes"
                            Tag="TaskCodes"
                            Click="EditorTabButton_Click"
                            Style="{StaticResource EditorTabButtonStyle}" />
                    <Button x:Name="CategoriesTabButton"
                            Content="Categories"
                            Tag="Categories"
                            Click="EditorTabButton_Click"
                            Style="{StaticResource EditorTabButtonStyle}" />
                </StackPanel>
            </Grid>

            <StackPanel x:Name="TaskCodesToolbar" Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Add above" Style="{StaticResource RoundedActionButtonStyle}" Click="AddTaskAbove_Click" />
                <Button Content="Add below" Style="{StaticResource RoundedActionButtonStyle}" Click="AddTaskBelow_Click" />
                <Button Content="Delete" Style="{StaticResource RoundedActionButtonStyle}" Click="DeleteTask_Click" />
                <Button Content="A-Z sort" Style="{StaticResource RoundedActionButtonStyle}" Click="SortTasks_Click" />
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#64748B"
                           Text="Imported means this task code came from raw imported data, so the code itself stays locked." />
            </StackPanel>

            <StackPanel x:Name="CategoriesToolbar" Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12" Visibility="Collapsed">
                <Button Content="Add" Style="{StaticResource RoundedActionButtonStyle}" Click="AddCategory_Click" />
                <Button Content="Delete" Style="{StaticResource RoundedActionButtonStyle}" Click="DeleteCategory_Click" />
                <ComboBox x:Name="MergeTargetCombo"
                          ItemsSource="{Binding ProjectCategories}"
                          DisplayMemberPath="Name"
                          Width="220"
                          Height="36"
                          Margin="0,0,10,0"
                          VerticalContentAlignment="Center" />
                <Button Content="Merge into" Style="{StaticResource RoundedActionButtonStyle}" Click="MergeCategory_Click" />
                <Button Content="A-Z sort" Style="{StaticResource RoundedActionButtonStyle}" Click="SortCategories_Click" />
            </StackPanel>

            <Grid Grid.Row="3">
                <Border x:Name="TaskCodesPanel"
                        Background="White"
                        BorderBrush="#DCE4EE"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="8">
                    <DataGrid x:Name="TaskCodesGrid"
                              Style="{StaticResource EditorDataGridStyle}"
                              ItemsSource="{Binding ProjectTaskCodes}"
                              AutoGenerateColumns="False"
                              BeginningEdit="TaskCodesGrid_BeginningEdit"
                              PreviewMouseLeftButtonDown="EditorGrid_PreviewMouseLeftButtonDown"
                              PreviewMouseRightButtonDown="EditorGrid_PreviewMouseRightButtonDown"
                              PreviewMouseRightButtonUp="EditorGrid_PreviewMouseRightButtonUp"
                              MouseMove="TaskCodesGrid_MouseMove"
                              PreviewMouseMove="EditorGrid_PreviewMouseMove"
                              Drop="TaskCodesGrid_Drop"
                              AllowDrop="True"
                              PreviewTextInput="EditorGrid_PreviewTextInput"
                              PreviewKeyDown="EditorGrid_PreviewKeyDown"
                              MouseDoubleClick="EditorGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Task code"
                                                Binding="{Binding SystemCode, UpdateSourceTrigger=PropertyChanged}"
                                                Width="220"
                                                ElementStyle="{StaticResource EditorTextColumnDisplayStyle}"
                                                EditingElementStyle="{StaticResource EditorTextColumnEditingStyle}" />
                            <DataGridTemplateColumn Header="Task name"
                                                    Width="420"
                                                    SortMemberPath="TaskName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectTaskCode}">
                                        <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource EditorTextColumnEditingStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectTaskCode}">
                                        <TextBox Text="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource EditorTextColumnEditingStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridCheckBoxColumn Header="Imported"
                                                    Binding="{Binding IsRawDataCode}"
                                                    IsReadOnly="True"
                                                    Width="110">
                                <DataGridCheckBoxColumn.ElementStyle>
                                    <Style TargetType="CheckBox">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="IsHitTestVisible" Value="False" />
                                    </Style>
                                </DataGridCheckBoxColumn.ElementStyle>
                            </DataGridCheckBoxColumn>
                            <DataGridTemplateColumn Header="Icon" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectTaskCode}">
                                        <Button Tag="{Binding}"
                                                Click="TaskIconButton_Click"
                                                Style="{StaticResource RoundedActionButtonStyle}"
                                                Padding="10,4"
                                                Width="128"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding IconPreview}"
                                                       Width="16"
                                                       Height="16"
                                                       Margin="0,0,8,0" />
                                                <TextBlock Text="Choose" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Colour" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectTaskCode}">
                                        <Button Tag="{Binding}"
                                                Click="TaskColourButton_Click"
                                                Style="{StaticResource RoundedActionButtonStyle}"
                                                Padding="10,4"
                                                Width="136"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="14"
                                                        Height="14"
                                                        Margin="0,0,8,0"
                                                        CornerRadius="4"
                                                        BorderBrush="#CBD5E1"
                                                        BorderThickness="1"
                                                        Background="{Binding IconColorBrush}" />
                                                <TextBlock Text="{Binding IconColorLabel}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border x:Name="CategoriesPanel"
                        Background="White"
                        BorderBrush="#DCE4EE"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="8"
                        Visibility="Collapsed">
                    <DataGrid x:Name="CategoriesGrid"
                              Style="{StaticResource EditorDataGridStyle}"
                              ItemsSource="{Binding ProjectCategories}"
                              AutoGenerateColumns="False"
                              PreviewMouseRightButtonDown="EditorGrid_PreviewMouseRightButtonDown"
                              PreviewMouseRightButtonUp="EditorGrid_PreviewMouseRightButtonUp"
                              PreviewMouseMove="EditorGrid_PreviewMouseMove"
                              PreviewTextInput="EditorGrid_PreviewTextInput"
                              PreviewKeyDown="EditorGrid_PreviewKeyDown"
                              PreviewMouseLeftButtonDown="EditorGrid_PreviewMouseLeftButtonDown"
                              MouseDoubleClick="EditorGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Category"
                                                    Width="420"
                                                    SortMemberPath="Name">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectCategory}">
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource EditorTextColumnEditingStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectCategory}">
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource EditorTextColumnEditingStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Icon" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectCategory}">
                                        <Button Tag="{Binding}"
                                                Click="CategoryIconButton_Click"
                                                Style="{StaticResource RoundedActionButtonStyle}"
                                                Padding="10,4"
                                                Width="128"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding IconPreview}"
                                                       Width="16"
                                                       Height="16"
                                                       Margin="0,0,8,0" />
                                                <TextBlock Text="Choose" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Colour" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type models:ProjectCategory}">
                                        <Button Tag="{Binding}"
                                                Click="CategoryColourButton_Click"
                                                Style="{StaticResource RoundedActionButtonStyle}"
                                                Padding="10,4"
                                                Width="136"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="14"
                                                        Height="14"
                                                        Margin="0,0,8,0"
                                                        CornerRadius="4"
                                                        BorderBrush="#CBD5E1"
                                                        BorderThickness="1"
                                                        Background="{Binding ColorBrush}" />
                                                <TextBlock Text="{Binding ColorLabel}" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Style="{StaticResource RoundedActionButtonStyle}" Click="Cancel_Click" />
                <Button Content="Save" Style="{StaticResource RoundedActionButtonStyle}" Click="Save_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
