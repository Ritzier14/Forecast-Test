<Window x:Class="ProjectCostForecast.App.TaskCategoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ProjectCostForecast.App.Models"
        Title="Task and Category Editor"
        Width="920"
        Height="620"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FC">
    <Window.Resources>
        <Style x:Key="EditorButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="74" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D6E0EC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Task and category metadata"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#0F172A"
                   Margin="0,0,0,12" />

        <TabControl x:Name="EditorTabs" Grid.Row="1">
            <TabItem Header="Task Codes">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Add above" Style="{StaticResource EditorButtonStyle}" Click="AddTaskAbove_Click" />
                        <Button Content="Add below" Style="{StaticResource EditorButtonStyle}" Click="AddTaskBelow_Click" />
                        <Button Content="Delete" Style="{StaticResource EditorButtonStyle}" Click="DeleteTask_Click" />
                        <Button Content="A-Z sort" Style="{StaticResource EditorButtonStyle}" Click="SortTasks_Click" />
                    </StackPanel>
                    <DataGrid x:Name="TaskCodesGrid"
                              ItemsSource="{Binding ProjectTaskCodes}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              BeginningEdit="TaskCodesGrid_BeginningEdit"
                              PreviewMouseLeftButtonDown="TaskCodesGrid_PreviewMouseLeftButtonDown"
                              MouseMove="TaskCodesGrid_MouseMove"
                              Drop="TaskCodesGrid_Drop"
                              AllowDrop="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="System code"
                                                Binding="{Binding SystemCode, UpdateSourceTrigger=PropertyChanged}"
                                                Width="150" />
                            <DataGridTextColumn Header="Task name"
                                                Binding="{Binding TaskName, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                            <DataGridCheckBoxColumn Header="Raw"
                                                    Binding="{Binding IsRawDataCode}"
                                                    IsReadOnly="True"
                                                    Width="70" />
                            <DataGridTextColumn Header="Icon"
                                                Binding="{Binding IconKey, UpdateSourceTrigger=PropertyChanged}"
                                                Width="150" />
                            <DataGridTextColumn Header="Colour"
                                                Binding="{Binding IconColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Categories">
                <DockPanel Margin="0,12,0,0">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Add" Style="{StaticResource EditorButtonStyle}" Click="AddCategory_Click" />
                        <Button Content="Delete" Style="{StaticResource EditorButtonStyle}" Click="DeleteCategory_Click" />
                        <Button Content="Merge into" Style="{StaticResource EditorButtonStyle}" Click="MergeCategory_Click" />
                        <ComboBox x:Name="MergeTargetCombo"
                                  ItemsSource="{Binding ProjectCategories}"
                                  DisplayMemberPath="Name"
                                  Width="220"
                                  Margin="0,0,8,0" />
                        <Button Content="A-Z sort" Style="{StaticResource EditorButtonStyle}" Click="SortCategories_Click" />
                    </StackPanel>
                    <DataGrid x:Name="CategoriesGrid"
                              ItemsSource="{Binding ProjectCategories}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category"
                                                Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                            <DataGridTextColumn Header="Colour"
                                                Binding="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                Width="140" />
                            <DataGridTextColumn Header="Icon"
                                                Binding="{Binding IconKey, UpdateSourceTrigger=PropertyChanged}"
                                                Width="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Style="{StaticResource EditorButtonStyle}" Click="Cancel_Click" />
            <Button Content="Save" Style="{StaticResource EditorButtonStyle}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
