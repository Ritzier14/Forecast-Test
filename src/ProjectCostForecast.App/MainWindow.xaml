<Window x:Class="ProjectCostForecast.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ProjectCostForecast.App.Models"
        xmlns:vm="clr-namespace:ProjectCostForecast.App.ViewModels"
        xmlns:local="clr-namespace:ProjectCostForecast.App"
        Title="{Binding AppWindowTitle, FallbackValue=Project Cost Forecast - Release Candidate}"
        Width="1500"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        Background="{StaticResource ShellBackground}"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <models:ForecastGroupSummaryConverter x:Key="ForecastGroupSummaryConverter" />
        <models:ForecastGroupMonthSummaryConverter x:Key="ForecastGroupMonthSummaryConverter" />
        <models:DateOnlyTextConverter x:Key="DateOnlyText" />
        <models:OutlineIndentConverter x:Key="OutlineIndent" />
        <local:FormattedCommentConverter x:Key="FormattedComment" />
        <DataTemplate x:Key="ForecastMonthColumnHeaderTemplate">
            <Grid SnapsToDevicePixels="True">
                <Border BorderBrush="#DEE6EF" BorderThickness="0,1,1,1" Background="White" />
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{Binding PrimaryBackground}" BorderBrush="#E4EAF2" BorderThickness="0,0,0,1" Padding="4,6,4,5">
                        <TextBlock Text="{Binding PrimaryLabel}" HorizontalAlignment="Center" FontWeight="Bold" FontStyle="Italic" />
                    </Border>
                    <Border Grid.Row="1" Background="{Binding SecondaryBackground}" BorderBrush="#E4EAF2" BorderThickness="0,0,0,1" Padding="4,5,4,6">
                        <TextBlock Text="{Binding SecondaryLabel}" HorizontalAlignment="Center" FontWeight="Bold" FontStyle="Italic" />
                    </Border>
                </Grid>
                <Border HorizontalAlignment="Left" Width="1" Background="Black" Visibility="{Binding LeftSolidSeparatorVisibility}" />
                <Border HorizontalAlignment="Right" Width="1" Background="Black" Visibility="{Binding RightSolidSeparatorVisibility}" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="ForecastMonthCellTemplate">
            <Grid SnapsToDevicePixels="True">
                <Border BorderBrush="{StaticResource GridLineBrush}" BorderThickness="0,0,1,1" Background="{Binding ValueBackground}" />
                <TextBlock Text="{Binding Value, Converter={StaticResource AccountingNoDecimalsConverter}}" HorizontalAlignment="Stretch" TextAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" FontStyle="Italic" Padding="4,3" />
                <Border HorizontalAlignment="Left" Width="1" Background="Black" Visibility="{Binding ColumnDefinition.LeftSolidSeparatorVisibility}" />
                <Border HorizontalAlignment="Right" Width="1" Background="Black" Visibility="{Binding ColumnDefinition.RightSolidSeparatorVisibility}" />
            </Grid>
        </DataTemplate>
        <Style x:Key="WorkspaceViewPillItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Background="Transparent">
                            <ContentPresenter Margin="0,7,0,9"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                            <Border x:Name="ActiveUnderline"
                                    Height="3"
                                    Background="#3B82F6"
                                    VerticalAlignment="Bottom"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1E3A5F" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#2563EB" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="ActiveUnderline" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="WorkspaceViewPillTemplate">
            <Grid MinWidth="118" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="16"
                        Height="14"
                        Margin="0,0,8,0"
                        BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                        BorderThickness="1.5"
                        CornerRadius="2"
                        VerticalAlignment="Center">
                    <Grid Margin="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Column="1" Grid.RowSpan="3" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Opacity="0.7" />
                        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Opacity="0.7" />
                    </Grid>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding Name}"
                           Width="{Binding ElementName=WorkspaceViewEditor, Path=Width}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox x:Name="WorkspaceViewEditor"
                         Grid.Column="1"
                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="0"
                         Padding="0"
                         Margin="0"
                         MinHeight="0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                         FontSize="14"
                         FontWeight="SemiBold"
                         FocusVisualStyle="{x:Null}"
                         Loaded="WorkspaceViewName_Loaded"
                         IsVisibleChanged="WorkspaceViewName_IsVisibleChanged"
                         GotKeyboardFocus="WorkspaceViewName_GotKeyboardFocus"
                         TextChanged="WorkspaceViewName_TextChanged"
                         LostFocus="WorkspaceViewName_LostFocus"
                         KeyDown="WorkspaceViewName_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </DataTemplate>

        <Style x:Key="WorkspaceViewAddButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D7E0EA" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="AddPillBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AddPillBorder" Property="Background" Value="#F1F5F9" />
                                <Setter TargetName="AddPillBorder" Property="BorderBrush" Value="#C7D2DE" />
                                <Setter Property="Foreground" Value="#334155" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="AddPillBorder" Property="Background" Value="#D9EAFD" />
                                <Setter TargetName="AddPillBorder" Property="BorderBrush" Value="#86ACDA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LeftForecastActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="27" />
            <Setter Property="Margin" Value="0,1,0,1" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#53617F" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionBackground" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ActionBackground" Property="Background" Value="#EEF4FF"/><Setter Property="Foreground" Value="#1463F3"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ActionBackground" Property="Background" Value="#E0EBFF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ForecastStatePillButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="#F2F1EE" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#3F3B36" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PillBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="15"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="#E6E4DF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PillBorder" Property="Background" Value="#DCD8D1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ForecastStatePillCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#C9C9C9" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseCircle"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-1,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseCircle" Property="Background" Value="#9CA3AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseCircle" Property="Background" Value="#6B7280" />
                                <Setter TargetName="CloseCircle" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="CloseCircle" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CurrentPeriodActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1463F3" />
            <Setter Property="BorderBrush" Value="#DCE4EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ActionCircle"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionCircle" Property="Background" Value="#EEF4FF" />
                                <Setter TargetName="ActionCircle" Property="BorderBrush" Value="#BFD6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionCircle" Property="Background" Value="#DCEBFF" />
                                <Setter TargetName="ActionCircle" Property="BorderBrush" Value="#9FC0FB" />
                                <Setter TargetName="ActionCircle" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ActionCircle" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="WorkspaceViewStripTemplate">
            <Grid Margin="8,4,0,10">
                <Border Height="1"
                        Background="#DCE4EE"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentWorkspaceViews.Count}" Value="1">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1">
                    <ListBox ItemsSource="{Binding CurrentWorkspaceViews}"
                             SelectedItem="{Binding SelectedWorkspaceView, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource WorkspaceViewPillItemStyle}"
                             ItemTemplate="{StaticResource WorkspaceViewPillTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Center"
                             PreviewMouseLeftButtonDown="WorkspaceViewTabs_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="WorkspaceViewTabs_PreviewMouseMove"
                             PreviewMouseLeftButtonUp="WorkspaceViewTabs_PreviewMouseLeftButtonUp"
                             MouseDoubleClick="WorkspaceViewTabControl_MouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                    <Button Content="+"
                            Style="{StaticResource WorkspaceViewAddButtonStyle}"
                            Click="AddWorkspaceViewButton_Click" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="DetailWorkspaceViewStripTemplate">
            <Grid Margin="8,4,0,10">
                <Border Height="1"
                        Background="#DCE4EE"
                        VerticalAlignment="Bottom">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentDetailWorkspaceViews.Count}" Value="1">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Panel.ZIndex="1">
                    <ListBox ItemsSource="{Binding CurrentDetailWorkspaceViews}"
                             SelectedItem="{Binding SelectedDetailWorkspaceView, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource WorkspaceViewPillItemStyle}"
                             ItemTemplate="{StaticResource WorkspaceViewPillTemplate}"
                             Background="Transparent"
                             BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Center"
                             PreviewMouseLeftButtonDown="WorkspaceViewTabs_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="WorkspaceViewTabs_PreviewMouseMove"
                             PreviewMouseLeftButtonUp="WorkspaceViewTabs_PreviewMouseLeftButtonUp"
                             MouseDoubleClick="WorkspaceViewTabControl_MouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                    </ListBox>
                    <Button Content="+"
                            Style="{StaticResource WorkspaceViewAddButtonStyle}"
                            Click="AddDetailWorkspaceViewButton_Click" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="ForecastWorkspaceTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TabPanel Grid.Column="0"
                                          Margin="0,0,0,1"
                                          IsItemsHost="True"
                                          Background="Transparent"
                                          Panel.ZIndex="1" />
                                <Border x:Name="HeaderUnderline"
                                        Grid.ColumnSpan="3"
                                        Height="1"
                                        VerticalAlignment="Bottom"
                                        Background="#DCE4EE"
                                        Panel.ZIndex="0" />
                            </Grid>
                            <ContentPresenter Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              ContentSource="SelectedContent" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items.Count}" Value="1">
                                <Setter TargetName="HeaderUnderline" Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#F7F9FC">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E5EAF3" BorderThickness="0,0,1,0">
            <Grid Margin="12,20,12,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="10,0,0,32">
                    <Image Source="/Assets/Icons/png/ic_app_logo_32.png" Width="32" Height="32" />
                    <TextBlock Text="Foresight" Margin="12,0,0,0" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#111936" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Assets/Icons/png/ic_nav_home_20.png" Width="20" Height="20" />
                            <TextBlock Text="Overview" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#43506F" />
                        </StackPanel>
                    </Border>
                    <Border Background="#EEF4FF" CornerRadius="8" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Image Source="/Assets/Icons/png/ic_nav_forecasts_20.png" Width="20" Height="20" />
                            <TextBlock Grid.Column="1" Text="Forecasts" Margin="12,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1463F3" />
                            <TextBlock Grid.Column="2" Text="⌃" Foreground="#1463F3" FontSize="15" />
                        </Grid>
                    </Border>
                    <StackPanel Margin="42,7,0,20">
                        <TextBlock Text="●   Default" Foreground="#1463F3" FontWeight="SemiBold" Margin="0,5" />
                        <TextBlock Text="○   Scenario A" Foreground="#53617F" Margin="0,5" />
                        <TextBlock Text="○   Scenario B" Foreground="#53617F" Margin="0,5" />
                        <Border BorderBrush="#E5EAF3" BorderThickness="0,1,0,0" Margin="0,8,10,4" />
                        <TextBlock Text="PROJECT ACTIONS" Foreground="#8A97AC" FontSize="9" FontWeight="Bold" Margin="10,5,0,3" />
                        <Button Content="Open project" Command="{Binding OpenProjectCommand}" ToolTip="Open a project file" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="Save project" Command="{Binding SaveProjectCommand}" ToolTip="Save the current project" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="Save project as" Command="{Binding SaveProjectAsCommand}" ToolTip="Save the current project under a new name" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="Clear all" Command="{Binding ClearAllCommand}" ToolTip="Clear all project records" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="Import CSV" Command="{Binding ImportCsvCommand}" ToolTip="Import cost transactions from CSV" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="Export CSV" Command="{Binding ExportTransactionsCommand}" ToolTip="Export transactions to CSV" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="New month" Command="{Binding NewMonthCommand}" ToolTip="Set up the next forecast month" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="View saved month" Command="{Binding ViewSavedMonthCommand}" ToolTip="Open a previously saved month" Style="{StaticResource LeftForecastActionButtonStyle}" />
                        <Button Content="Recalculate" Command="{Binding RecalculateCommand}" ToolTip="Recalculate all forecast totals" Style="{StaticResource LeftForecastActionButtonStyle}" />
                    </StackPanel>
                    <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal"><Image Source="/Assets/Icons/png/ic_nav_reports_20.png" Width="20" Height="20"/><TextBlock Text="Reports" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#43506F"/></StackPanel>
                    </Border>
                    <Border CornerRadius="8" Padding="14,10" Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal"><Image Source="/Assets/Icons/png/ic_nav_resources_20.png" Width="20" Height="20"/><TextBlock Text="Resources" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#43506F"/></StackPanel>
                    </Border>
                    <Border CornerRadius="8" Padding="14,10">
                        <StackPanel Orientation="Horizontal"><Image Source="/Assets/Icons/png/ic_nav_settings_20.png" Width="20" Height="20"/><TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#43506F"/></StackPanel>
                    </Border>
                </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" BorderBrush="#E5EAF3" BorderThickness="0,1,0,0" Padding="14,17,8,0">
                    <StackPanel Orientation="Horizontal"><Image Source="/Assets/Icons/png/ic_collapse_20.png" Width="20" Height="20"/><TextBlock Text="Collapse" Margin="12,0,0,0" Foreground="#596784" VerticalAlignment="Center"/></StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F7F9FC">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="2" Height="215" VerticalAlignment="Top" IsHitTestVisible="False">
                <Grid ClipToBounds="True">
                    <Image Source="/Assets/Backgrounds/bg_header_lake_panorama.png"
                           Stretch="UniformToFill"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch" />
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FFFFFFFF" Offset="0" />
                                <GradientStop Color="#F5FFFFFF" Offset="0.23" />
                                <GradientStop Color="#99FFFFFF" Offset="0.46" />
                                <GradientStop Color="#18FFFFFF" Offset="0.70" />
                                <GradientStop Color="#00FFFFFF" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle VerticalAlignment="Bottom" Height="46">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#00F7F9FC" Offset="0" />
                                <GradientStop Color="#FFF7F9FC" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>
            <Border Grid.Row="0" MinHeight="104" Padding="22,12">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Project Cost Forecast" FontSize="23" FontWeight="SemiBold" Foreground="#101735" />
                        <TextBlock Text="{Binding Header.ProjectTitle}" FontSize="13" FontWeight="SemiBold" Foreground="#17213F" Margin="0,3,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Loaded workbook: " Foreground="#6A7897" FontSize="10" />
                            <TextBlock Text="{Binding Header.SourceWorkbook}" Foreground="#6A7897" FontSize="10" />
                            <Border Width="1" Height="14" Background="#CAD4E2" Margin="14,0" />
                            <Image Source="/Assets/Icons/png/ic_badge_validation_ok_16.png" Width="16" Height="16" Margin="0,0,6,0" />
                            <TextBlock Text="All data validated" Foreground="#52617D" FontSize="10" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Command="{Binding NewMonthCommand}" ToolTip="Save a month snapshot and set up the next month" Background="White" BorderBrush="#DCE4EF" BorderThickness="1" Padding="15,9" VerticalAlignment="Top">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="22" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="/Assets/Icons/png/ic_calendar_18.png" Width="18" Height="18" Margin="0,0,9,0" />
                                <TextBlock Text="Current period" Foreground="#34415F" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Border Background="#EEF4FF" CornerRadius="12" Padding="9,3" Margin="12,0,6,0"><TextBlock Text="{Binding Header.CurrentPeriod}" Foreground="#1463F3" FontWeight="SemiBold" /></Border>
                                <TextBlock Text="New month" Foreground="#34415F" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CurrentPeriodActionsButton"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource CurrentPeriodActionButtonStyle}"
                                ToolTip="Current period actions"
                                Click="CurrentPeriodActionsButton_Click">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="View saved month" Command="{Binding ViewSavedMonthCommand}" />
                                    <MenuItem Header="New month" Command="{Binding NewMonthCommand}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Path Data="M 5 8 L 10 13 L 15 8"
                                  Stroke="#1463F3"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="0,6,0,10"
                    Background="Transparent"
                    AllowDrop="True"
                    MouseRightButtonUp="KpiStrip_MouseRightButtonUp"
                    DragOver="KpiStrip_DragOver"
                    DragLeave="KpiStrip_DragLeave"
                    Drop="KpiStrip_Drop">
                <Grid>
                    <ScrollViewer x:Name="KpiScrollViewer" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PreviewMouseRightButtonDown="KpiScrollViewer_PreviewMouseRightButtonDown" PreviewMouseMove="KpiScrollViewer_PreviewMouseMove" PreviewMouseRightButtonUp="KpiScrollViewer_PreviewMouseRightButtonUp">
                        <ItemsControl x:Name="KpiItemsControl" ItemsSource="{Binding KpiPills}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource KpiCard}"
                                            Width="190"
                                            Tag="{Binding Id}"
                                            AllowDrop="True"
                                            MouseRightButtonUp="KpiCard_MouseRightButtonUp"
                                            PreviewMouseLeftButtonDown="KpiCard_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="KpiCard_PreviewMouseMove"
                                            PreviewMouseLeftButtonUp="KpiCard_PreviewMouseLeftButtonUp"
                                            DragOver="KpiCard_DragOver"
                                            DragLeave="KpiCard_DragLeave"
                                            Drop="KpiCard_Drop">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="16" Background="#F2F6FF" VerticalAlignment="Top">
                                                <Image Source="{Binding IconSource}" Width="22" Height="22" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ValueText}" Foreground="#101735" FontSize="16" FontWeight="Bold" Margin="0,1,0,0" />
                                            <TextBlock Text="{Binding ComparisonText}"
                                                       Visibility="{Binding ComparisonVisibility}"
                                                       Foreground="#7C3AED"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Margin="0,3,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Subtext}" Foreground="{StaticResource MutedTextBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Background="#F7F9FC">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="MainWorkspaceColumn" Width="3*" />
                    <ColumnDefinition x:Name="WorkspaceSplitterColumn" Width="12" />
                    <ColumnDefinition x:Name="DetailWorkspaceColumn" Width="1.25*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Background="#FFF5F5" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="7" Padding="6,4" Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActivePeriodWarnings.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ItemsControl ItemsSource="{Binding ActivePeriodWarnings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#B91C1C" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap" Margin="2,1" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TabControl x:Name="WorkspaceTabControl"
                                    Style="{StaticResource ForecastWorkspaceTabControlStyle}"
                                    PreviewMouseLeftButtonDown="WorkspaceTabs_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="WorkspaceTabs_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="WorkspaceTabs_PreviewMouseLeftButtonUp"
                                    SelectionChanged="WorkspaceTabControl_SelectionChanged">
                            <TabItem Tag="CTC Forecast">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal"
                                                Tag="CTC Forecast"
                                                MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp">
                                        <Image x:Name="ForecastTabHeaderIcon"
                                               Source="/Assets/Icons/png/ic_tab_forecast_16.png"
                                               Width="16"
                                               Height="16"
                                               Margin="0,0,7,0"
                                               Tag="CTC Forecast" />
                                        <TextBlock Text="Forecast" />
                                    </StackPanel>
                                </TabItem.Header>
                                <DockPanel LastChildFill="True">
                                    <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceViewStripTemplate}" />
                                    <WrapPanel x:Name="ForecastGridStatePillPanel"
                                               DockPanel.Dock="Top"
                                               Margin="8,0,0,8"
                                               Visibility="Collapsed" />
                                    <Grid x:Name="ForecastGridHost">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.RowSpan="2"
                                                Background="White"
                                                BorderBrush="#DCE4EE"
                                                BorderThickness="1"
                                                CornerRadius="10" />
                                        <Canvas x:Name="ForecastYearBandCanvas"
                                                Grid.Row="0"
                                                ClipToBounds="True"
                                                IsHitTestVisible="True"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True"
                                                Panel.ZIndex="10" />
                                        <Button Grid.Row="0"
                                                x:Name="ForecastGroupToggleButton"
                                                Width="24"
                                                Height="24"
                                                Margin="6,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Panel.ZIndex="20"
                                                Click="ToggleForecastGroups_Click"
                                                ToolTip="Collapse all task groups">
                                            <Image x:Name="ForecastGroupToggleIcon"
                                                   Source="/Assets/Icons/png/ic_collapse_20.png"
                                                   Width="14"
                                                   Height="14" />
                                        </Button>
                                        <DataGrid x:Name="ForecastLinesGrid"
                                                  Grid.Row="1"
                                                  ItemsSource="{Binding ForecastLinesView}"
                                                  IsReadOnly="False"
                                                  RowHeight="30"
                                                  ColumnHeaderHeight="48"
                                                  Background="White"
                                                  BorderBrush="Transparent"
                                                  BorderThickness="0"
                                                  AlternationCount="2"
                                                  MouseLeave="ForecastLinesGrid_MouseLeave"
                                                  PreviewMouseLeftButtonDown="ForecastLinesGrid_PreviewMouseLeftButtonDown"
                                                  PreviewMouseLeftButtonUp="ForecastLinesGrid_PreviewMouseLeftButtonUp"
                                                   PreviewMouseMove="ForecastLinesGrid_PreviewMouseMove"
                                                  Sorting="ForecastLinesGrid_Sorting"
                                                  >
                                            <DataGrid.GroupStyle>
                                                <GroupStyle AlternationCount="6">
                                                    <GroupStyle.ContainerStyle>
                                                        <Style TargetType="{x:Type GroupItem}">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                                        <Expander IsExpanded="True" Background="Transparent" BorderThickness="0" Margin="0,1,0,0">
                                                                            <Expander.Template>
                                                                                <ControlTemplate TargetType="Expander">
                                                                                    <DockPanel LastChildFill="True">
                                                                                        <ContentPresenter DockPanel.Dock="Top" Content="{TemplateBinding Header}" />
                                                                                        <ContentPresenter x:Name="ExpandSite" Content="{TemplateBinding Content}" />
                                                                                    </DockPanel>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsExpanded" Value="False"><Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed"/></Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Expander.Template>
                                                                            <Expander.Header>
                                                                                <local:ForecastGroupHeaderPresenter Items="{Binding Items}"
                                                                                                                    GroupName="{Binding Name}"
                                                                                                                    OwningGrid="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                                                                    GroupIndex="{Binding RelativeSource={RelativeSource AncestorType=GroupItem}, Path=(ItemsControl.AlternationIndex)}" />
                                                                            </Expander.Header>
                                                                            <ItemsPresenter />
                                                                        </Expander>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </GroupStyle.ContainerStyle>
                                                </GroupStyle>
                                            </DataGrid.GroupStyle>
                                        </DataGrid>
                                        <Canvas x:Name="ForecastFreezeBoundaryCanvas"
                                                Grid.RowSpan="2"
                                                ClipToBounds="True"
                                                IsHitTestVisible="False"
                                                SnapsToDevicePixels="True"
                                                UseLayoutRounding="True"
                                                Panel.ZIndex="30" />
                                        <Border x:Name="ForecastAddRowStrip"
                                                Grid.Row="1"
                                                Height="34"
                                                Margin="0,0,0,48"
                                                VerticalAlignment="Bottom"
                                                Background="White"
                                                BorderBrush="#DCE4EE"
                                                BorderThickness="0,1,0,0"
                                                Panel.ZIndex="35">
                                            <Button x:Name="AddForecastRowButton"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource ForecastStatePillButtonStyle}"
                                                    Click="AddForecastRowButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="+"
                                                               Margin="0,0,5,0"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="Add row" />
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </TabItem>

                            <TabItem x:Name="ManagementResourcesTab" Tag="Resources">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Resources" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="ResourcesTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_resources_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Resources"/><TextBlock Text="Resources"/></StackPanel></TabItem.Header>
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Margin="4,0,4,10"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="Right-click a row in CTC Forecast and select Add as management task. Rates are editable below; each month uses a standard 160 hours." />

                                    <TextBlock Grid.Row="1" Margin="4,0,0,5" FontSize="14" FontWeight="SemiBold" Text="Allocation by month (%)" />
                                    <DataGrid x:Name="ManagementResourceAllocationGrid"
                                              Grid.Row="2"
                                              ItemsSource="{Binding ManagementResourceAllocationRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="False"
                                              Loaded="ManagementResourceGrid_Loaded"
                                              PreviewMouseLeftButtonDown="ManagementResourceAllocationGrid_PreviewMouseLeftButtonDown"
                                              PreviewTextInput="ManagementResourceAllocationGrid_PreviewTextInput"
                                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                              FrozenColumnCount="4" />

                                    <TextBlock Grid.Row="3" Margin="4,10,0,5" FontSize="14" FontWeight="SemiBold" Text="Calculated hours (160 hours per month)" />
                                    <DataGrid x:Name="ManagementResourceHoursGrid"
                                              Grid.Row="4"
                                              ItemsSource="{Binding ManagementResourceHoursRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              Loaded="ManagementResourceGrid_Loaded"
                                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                              FrozenColumnCount="4" />

                                    <TextBlock Grid.Row="5" Margin="4,10,0,5" FontSize="14" FontWeight="SemiBold" Text="Monthly management cost (hours × rate)" />
                                    <DataGrid x:Name="ManagementResourceCostGrid"
                                              Grid.Row="6"
                                              ItemsSource="{Binding ManagementResourceCostRows}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              Loaded="ManagementResourceGrid_Loaded"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              FrozenColumnCount="4" />
                                </Grid>
                            </TabItem>

                            <TabItem Tag="Raw Transactions">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Raw Transactions" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="RawTransactionsTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_raw_transactions_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Raw Transactions"/><TextBlock Text="Raw Transactions"/></StackPanel></TabItem.Header>
                                <DockPanel LastChildFill="True">
                                    <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceViewStripTemplate}" />
                                    <Grid>
                                        <DataGrid x:Name="RawTransactionsGrid"
                                                  ItemsSource="{Binding RawTransactionsView}"
                                                  IsReadOnly="True"
                                                  Sorting="ColumnHighlightGrid_Sorting">
                                            <DataGrid.Style>
                                                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowRawTransactionsPivotByMonth}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Style>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="FY" Binding="{Binding FyPeriod}" Width="70" />
                                                <DataGridTextColumn Header="Task" Binding="{Binding TaskNumber}" Width="110" />
                                                <DataGridTextColumn Header="Date" Binding="{Binding DocDate}" Width="100" />
                                                <DataGridTextColumn Header="Resource" Binding="{Binding LedgerResourceName}" Width="200" />
                                                <DataGridTextColumn Header="Units" Binding="{Binding Units, StringFormat={}{0:N2}}" Width="80" />
                                                <DataGridTextColumn Header="Rate" Binding="{Binding UnitRate, Converter={StaticResource AccountingNoDecimalsConverter}, ConverterParameter=Decimals:2}" Width="85" />
                                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="95" />
                                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="70" />
                                                <DataGridTextColumn Header="Resource Code" Binding="{Binding ResourceCode}" Width="105" />
                                                <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="150" />
                                                <DataGridTextColumn Header="Narrative" Binding="{Binding Narrative1}" Width="220" />
                                                <DataGridTextColumn Header="Narrative 2" Binding="{Binding Narrative2}" Width="170" />
                                                <DataGridTextColumn Header="Narrative 3" Binding="{Binding Narrative3}" Width="170" />
                                                <DataGridTextColumn Header="Who" Binding="{Binding Who}" Width="150" />
                                                <DataGridTextColumn Header="ECM" Binding="{Binding EcmNumber}" Width="105" />
                                                <DataGridTextColumn Header="Manual Name" Binding="{Binding ManualName}" Width="170" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <DataGrid x:Name="RawTransactionsMonthlyPivotGrid"
                                                  ItemsSource="{Binding RawTransactionsMonthlyPivotRows}"
                                                  Sorting="ColumnHighlightGrid_Sorting">
                                            <DataGrid.Style>
                                                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowRawTransactionsPivotByMonth}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Style>
                                        </DataGrid>
                                    </Grid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Tag="Summary View">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Summary View" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="SummaryTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_summary_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Summary View"/><TextBlock Text="Summary"/></StackPanel></TabItem.Header>
                                <DockPanel LastChildFill="True">
                                    <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceViewStripTemplate}" />
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Sort categories" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox ItemsSource="{Binding CategorySortOptions}"
                                                  SelectedItem="{Binding SelectedCategorySortOption}"
                                                  DisplayMemberPath="Name"
                                                  Width="160"
                                                  Height="28" />
                                    </StackPanel>
                                    <Grid>
                                    <DataGrid x:Name="CategoryReportGrid" ItemsSource="{Binding CategorySummariesView}">
                                        <DataGrid.Style><Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}"><Setter Property="Visibility" Value="Visible" /><Style.Triggers><DataTrigger Binding="{Binding ShowSummaryViewByMonth}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style></DataGrid.Style>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Category" Binding="{Binding ProjectCode}" Width="190" />
                                            <DataGridTextColumn Header="Total Forecast" Binding="{Binding TotalForecast, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="130" />
                                            <DataGridTextColumn Header="Cost To Date" Binding="{Binding CostToDate, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="120" />
                                            <DataGridTextColumn Header="Month Cost" Binding="{Binding CurrentMonthCost, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="120" />
                                            <DataGridTextColumn Header="Planned Cost" Binding="{Binding PlannedCost, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="120" />
                                            <DataGridTextColumn Header="Budget" Binding="{Binding Budget, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="120" />
                                            <DataGridTextColumn Header="Budget Var" Binding="{Binding TotalBudgetVariance, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="120" />
                                            <DataGridTextColumn Header="Month Var" Binding="{Binding MonthForecastVariance, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <DataGrid x:Name="CategoryMonthlyPivotGrid" ItemsSource="{Binding CategoryMonthlyPivotRows}" Sorting="ColumnHighlightGrid_Sorting">
                                        <DataGrid.Style><Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ShowSummaryViewByMonth}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></DataGrid.Style>
                                    </DataGrid>
                                    </Grid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Tag="Monthly Report">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Monthly Report" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="MonthlyReportTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_monthly_report_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Monthly Report"/><TextBlock Text="Monthly Report"/></StackPanel></TabItem.Header>
                                <DockPanel LastChildFill="True">
                                <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceViewStripTemplate}" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="4">
                                        <Border BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White" Padding="0" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="220" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="0,0,1,0" Padding="10,8">
                                                    <TextBlock Text="{Binding Header.ReportTitle}" FontWeight="Bold" FontSize="15" />
                                                </Border>
                                                <Border Grid.Column="1" Padding="10,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Month/Period:" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Header.CurrentPeriod}" Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="The table below shows the spend vs AP/LTP budget for the current FY onwards. All values are generated live from the project data." FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,12" />

                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3.1*" />
                                                <ColumnDefinition Width="24" />
                                                <ColumnDefinition Width="1.25*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White">
                                                <StackPanel>
                                                    <Grid Background="#5B9BD5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.45*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="1.4*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="As at current period" Foreground="White" FontWeight="SemiBold" Margin="8,6" />
                                                        <TextBlock Grid.Column="1" Text="{Binding MonthlyReportFiscalYear1Label}" Foreground="White" FontWeight="SemiBold" Margin="8,6" />
                                                        <TextBlock Grid.Column="2" Text="{Binding MonthlyReportFiscalYear2Label}" Foreground="White" FontWeight="SemiBold" Margin="8,6" />
                                                        <TextBlock Grid.Column="3" Text="{Binding MonthlyReportFiscalYear3Label}" Foreground="White" FontWeight="SemiBold" Margin="8,6" />
                                                        <TextBlock Grid.Column="4" Text="Totals (current FY onwards)" Foreground="White" FontWeight="SemiBold" Margin="8,6" />
                                                    </Grid>

                                                    <ItemsControl ItemsSource="{Binding MonthlyReportFiscalSummaryRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border BorderBrush="#D8DEE8" BorderThickness="0,0,0,1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="1.45*" />
                                                                            <ColumnDefinition Width="1*" />
                                                                            <ColumnDefinition Width="1*" />
                                                                            <ColumnDefinition Width="1*" />
                                                                            <ColumnDefinition Width="1.4*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Label}" Margin="8,6" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Year1Value}" Margin="8,6" HorizontalAlignment="Right" />
                                                                        <TextBlock Grid.Column="2" Text="{Binding Year2Value}" Margin="8,6" HorizontalAlignment="Right" />
                                                                        <TextBlock Grid.Column="3" Text="{Binding Year3Value}" Margin="8,6" HorizontalAlignment="Right" />
                                                                        <TextBlock Grid.Column="4" Text="{Binding TotalValue}" Margin="8,6" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="2" BorderBrush="#7AA447" BorderThickness="1" Background="White">
                                                <StackPanel>
                                                    <Border Background="#7AA447" Padding="8,6">
                                                        <TextBlock Text="Contingency" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    </Border>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Total Project contingency" Margin="8,6" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ProjectContingencyTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" Margin="8,6" FontWeight="SemiBold" />
                                                    </Grid>
                                                    <Grid Background="#F7FAF3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Total expended" Margin="8,6" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ContingencyExpendedTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" Margin="8,6" FontWeight="SemiBold" />
                                                    </Grid>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Proposed expenditure" Margin="8,6" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ContingencyProposedTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" Margin="8,6" FontWeight="SemiBold" />
                                                    </Grid>
                                                    <Grid Background="#F7FAF3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Total Remaining" Margin="8,6" />
                                                        <TextBlock Grid.Column="1" Text="{Binding ContingencyRemainingTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" Margin="8,6" FontWeight="SemiBold" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Background="#9FB5DA" Padding="6,4" Margin="0,0,0,6">
                                            <TextBlock Text="Cost v Original Budget" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="The table below shows the final forecast cost vs initial budget, including variance from budget to date and variance from last period." FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <DataGrid ItemsSource="{Binding MonthlyReportCategoryRows}" Margin="0,0,0,14">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Project code" Binding="{Binding ProjectCode}" Width="150" />
                                                <DataGridTextColumn Header="TOTAL Forecast (CTC)" Binding="{Binding TotalForecastDisplay}" Width="120" />
                                                <DataGridTextColumn Header="Cost to Date" Binding="{Binding CostToDateDisplay}" Width="95" />
                                                <DataGridTextColumn Header="Planned cost (FCC)" Binding="{Binding PlannedCostDisplay}" Width="120" />
                                                <DataGridTextColumn Header="Initial Budget" Binding="{Binding InitialBudgetDisplay}" Width="120" />
                                                <DataGridTextColumn Header="Total budget variance" Binding="{Binding TotalBudgetVarianceDisplay}" Width="135" />
                                                <DataGridTextColumn Header="Last Month Planned Cost" Binding="{Binding LastMonthPlannedCostDisplay}" Width="145" />
                                                <DataGridTextColumn Header="Variance from last month" Binding="{Binding VarianceFromLastMonthDisplay}" Width="145" />
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <TextBlock Text="The table below shows the final forecast cost vs initial budget comments." FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <DataGrid ItemsSource="{Binding MonthlyReportVarianceCommentRows}" Margin="0,0,0,14">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Project code" Binding="{Binding ProjectCode}" Width="150" />
                                                <DataGridTextColumn Header="Total budget variance" Binding="{Binding TotalBudgetVarianceDisplay}" Width="120" />
                                                <DataGridTextColumn Header="Variance last month / To-date" Binding="{Binding VarianceLastMonthDisplay}" Width="150" />
                                                <DataGridTemplateColumn Header="Month variance comments" Width="240"><DataGridTemplateColumn.CellTemplate><DataTemplate><ContentControl Content="{Binding MonthVarianceComment, Converter={StaticResource FormattedComment}}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Total budget variance comments" Width="260"><DataGridTemplateColumn.CellTemplate><DataTemplate><ContentControl Content="{Binding TotalBudgetVarianceComment, Converter={StaticResource FormattedComment}}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="All month comments" Width="320"><DataGridTemplateColumn.CellTemplate><DataTemplate><ContentControl Content="{Binding AllMonthComments, Converter={StaticResource FormattedComment}}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Border Background="#9FB5DA" Padding="6,4" Margin="0,0,0,6">
                                            <TextBlock Text="Active Risks / Financial Events" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="The table below shows events that are ongoing or being mitigated but may need to be expended from contingency." FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <DataGrid ItemsSource="{Binding MonthlyReportRiskItems}" Margin="0,0,0,4">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="250" />
                                                <DataGridTextColumn Header="Project Code" Binding="{Binding ProjectCode}" Width="120" />
                                                <DataGridTextColumn Header="Current value" Binding="{Binding CurrentValue}" Width="110" />
                                                <DataGridTextColumn Header="Risk range" Binding="{Binding RiskRange}" Width="110" />
                                                <DataGridTextColumn Header="Comments" Binding="{Binding Comments}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBlock Text="{Binding ActiveRiskStatusText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,14" />

                                        <Border Background="#9FB5DA" Padding="6,4" Margin="0,0,0,6">
                                            <TextBlock Text="Plugged Rates" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="The table below shows sums that have been allowed for items that have not yet been priced." FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <DataGrid ItemsSource="{Binding MonthlyReportPluggedRateItems}" Margin="0,0,0,4">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="250" />
                                                <DataGridTextColumn Header="Project Code" Binding="{Binding ProjectCode}" Width="120" />
                                                <DataGridTextColumn Header="Current value" Binding="{Binding CurrentValue}" Width="110" />
                                                <DataGridTextColumn Header="Comments" Binding="{Binding Comments}" Width="*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBlock Text="{Binding PluggedRatesStatusText}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,4" />
                                    </StackPanel>
                                </ScrollViewer>
                                </DockPanel>
                            </TabItem>

                            <TabItem Tag="Pivot Builder">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Pivot Builder" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="PivotBuilderTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_pivot_builder_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Pivot Builder"/><TextBlock Text="Pivot Builder"/></StackPanel></TabItem.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="320" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White">
                                        <DataGrid x:Name="CustomPivotGrid"
                                                  ItemsSource="{Binding PivotResultRows}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  RowHeaderWidth="38"
                                                  IsReadOnly="True" />
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1,1,1,1" Background="#F8FAFC" Padding="10">
                                        <DockPanel LastChildFill="True">
                                            <StackPanel DockPanel.Dock="Top">
                                                <TextBlock Text="PivotTable Fields" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="Choose fields and send them to an area." Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,2,0,8" />
                                                <ListBox ItemsSource="{Binding PivotFields}"
                                                         SelectedItem="{Binding SelectedPivotField, Mode=TwoWay}"
                                                         DisplayMemberPath="Name"
                                                         Height="150"
                                                         BorderBrush="{StaticResource SoftBorderBrush}" />
                                                <UniformGrid Columns="2" Margin="0,8,0,12">
                                                    <Button Content="Rows" Command="{Binding AddPivotRowFieldCommand}" Margin="0,0,4,4" />
                                                    <Button Content="Columns" Command="{Binding AddPivotColumnFieldCommand}" Margin="4,0,0,4" />
                                                    <Button Content="Values" Command="{Binding AddPivotValueFieldCommand}" Margin="0,4,4,0" />
                                                    <Button Content="Filters" Command="{Binding AddPivotFilterFieldCommand}" Margin="4,4,0,0" />
                                                </UniformGrid>
                                                <Button Content="Clear pivot" Command="{Binding ClearPivotLayoutCommand}" HorizontalAlignment="Left" Margin="0,0,0,12" />
                                            </StackPanel>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White" Padding="6" Margin="0,0,0,6">
                                                    <DockPanel LastChildFill="True">
                                                        <Button DockPanel.Dock="Right" Content="Remove" Command="{Binding RemovePivotFilterFieldCommand}" Padding="6,3" Margin="6,0,0,0" />
                                                        <TextBlock DockPanel.Dock="Top" Text="Filters" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                        <ListBox ItemsSource="{Binding PivotFilterFields}" SelectedItem="{Binding SelectedPivotFilterField, Mode=TwoWay}" BorderThickness="0">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,4">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="95" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                        <ComboBox Grid.Column="1" ItemsSource="{Binding FilterValues}" SelectedItem="{Binding SelectedFilterValue, Mode=TwoWay}" Height="24" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </DockPanel>
                                                </Border>

                                                <Border Grid.Row="1" Grid.Column="0" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White" Padding="6" Margin="0,0,6,6">
                                                    <DockPanel LastChildFill="True">
                                                        <Button DockPanel.Dock="Bottom" Content="Remove" Command="{Binding RemovePivotRowFieldCommand}" Padding="6,3" Margin="0,6,0,0" />
                                                        <TextBlock DockPanel.Dock="Top" Text="Rows" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                                                        <ListBox ItemsSource="{Binding PivotRowFields}" SelectedItem="{Binding SelectedPivotRowField, Mode=TwoWay}" DisplayMemberPath="Name" BorderThickness="0" />
                                                    </DockPanel>
                                                </Border>
                                                <Border Grid.Row="1" Grid.Column="1" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White" Padding="6" Margin="0,0,0,6">
                                                    <DockPanel LastChildFill="True">
                                                        <Button DockPanel.Dock="Bottom" Content="Remove" Command="{Binding RemovePivotColumnFieldCommand}" Padding="6,3" Margin="0,6,0,0" />
                                                        <TextBlock DockPanel.Dock="Top" Text="Columns" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                                                        <ListBox ItemsSource="{Binding PivotColumnFields}" SelectedItem="{Binding SelectedPivotColumnField, Mode=TwoWay}" DisplayMemberPath="Name" BorderThickness="0" />
                                                    </DockPanel>
                                                </Border>
                                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Grid.RowSpan="2" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Background="White" Padding="6">
                                                    <DockPanel LastChildFill="True">
                                                        <Button DockPanel.Dock="Bottom" Content="Remove" Command="{Binding RemovePivotValueFieldCommand}" Padding="6,3" Margin="0,6,0,0" />
                                                        <TextBlock DockPanel.Dock="Top" Text="Values" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                                                        <ListBox ItemsSource="{Binding PivotValueFields}" SelectedItem="{Binding SelectedPivotValueField, Mode=TwoWay}" DisplayMemberPath="Name" BorderThickness="0" />
                                                    </DockPanel>
                                                </Border>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Tag="Contingency">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Contingency" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="ContingencyTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_contingency_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Contingency"/><TextBlock Text="Contingency"/></StackPanel></TabItem.Header>
                                <DockPanel LastChildFill="True">
                                <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceViewStripTemplate}" />
                                <DataGrid x:Name="ContingencyGrid" ItemsSource="{Binding ContingencyEntries}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="110" />
                                        <DataGridTextColumn Header="Expended" Binding="{Binding ContingencyExpended, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="110" />
                                        <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingContingency, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="110" />
                                        <DataGridTextColumn Header="Proposed" Binding="{Binding ProposedExpenditure, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="110" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="300" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Tag="Audit">
                                <TabItem.Header><StackPanel Orientation="Horizontal" Tag="Audit" MouseRightButtonUp="WorkspaceTabHeader_MouseRightButtonUp"><Image x:Name="AuditTabHeaderIcon" Source="/Assets/Icons/png/ic_tab_audit_16.png" Width="16" Height="16" Margin="0,0,7,0" Tag="Audit"/><TextBlock Text="Audit"/></StackPanel></TabItem.Header>
                                <DockPanel LastChildFill="True">
                                <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource WorkspaceViewStripTemplate}" />
                                <DataGrid x:Name="AuditGrid" ItemsSource="{Binding AuditEvents}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Changed" Binding="{Binding ChangedAt}" Width="155" />
                                        <DataGridTextColumn Header="User" Binding="{Binding ChangedBy}" Width="110" />
                                        <DataGridTextColumn Header="Entity" Binding="{Binding EntityType}" Width="115" />
                                        <DataGridTextColumn Header="ID" Binding="{Binding EntityId}" Width="80" />
                                        <DataGridTextColumn Header="Field" Binding="{Binding FieldName}" Width="130" />
                                        <DataGridTextColumn Header="Old" Binding="{Binding OldValue}" Width="120" />
                                        <DataGridTextColumn Header="New" Binding="{Binding NewValue}" Width="120" />
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Tag="Schedule">
                                <TabItem.Header><StackPanel Orientation="Horizontal"><TextBlock Text="◇" Foreground="#60708D" FontSize="16" Margin="0,0,7,0"/><TextBlock Text="Schedule"/></StackPanel></TabItem.Header>
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Top" Background="White" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8,6" Margin="0,0,0,8">
                                        <Border.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#64748B" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Style>
                                        </Border.Resources>
                                        <WrapPanel VerticalAlignment="Center">
                                            <Button Content="+ Activity" Padding="8,3" Margin="0,2,6,2" Click="AddScheduleActivity_Click" />
                                            <Button Content="+ Milestone" Padding="8,3" Margin="0,2,6,2" Click="AddScheduleMilestone_Click" />
                                            <Button Content="+ Heading" Padding="8,3" Margin="0,2,6,2" Click="AddScheduleHeading_Click" />
                                             <Button Content="+ Hammock" Padding="8,3" Margin="0,2,6,2" Click="AddScheduleHammock_Click" />
                                             <Button Content="Insert above" Padding="8,3" Margin="0,2,4,2" Click="ScheduleInsertAbove_Click" />
                                             <Button Content="Insert below" Padding="8,3" Margin="0,2,6,2" Click="ScheduleInsertBelow_Click" />
                                             <Button Content="Delete" Padding="8,3" Margin="0,2,14,2" Click="DeleteScheduleActivity_Click" />
                                            <Button Content="◀ Outdent" Padding="8,3" Margin="0,2,6,2" Click="ScheduleOutdent_Click" />
                                            <Button Content="Indent ▶" Padding="8,3" Margin="0,2,6,2" Click="ScheduleIndent_Click" />
                                            <Button Content="▲" Padding="8,3" Margin="0,2,3,2" Click="ScheduleMoveUp_Click" />
                                            <Button Content="▼" Padding="8,3" Margin="0,2,14,2" Click="ScheduleMoveDown_Click" />
                                             <Button Content="Link selected (FS)" Padding="8,3" Margin="0,2,14,2" Click="ScheduleLink_Click" />
                                             <Button Content="Break links" Padding="8,3" Margin="0,2,6,2" Click="ScheduleBreakLinks_Click" />
                                             <Button Content="Copy link source" Padding="8,3" Margin="0,2,6,2" Click="ScheduleCopyLinkSource_Click" />
                                             <Button Content="Paste link" Padding="8,3" Margin="0,2,8,2" Click="SchedulePasteLink_Click" />
                                             <TextBlock Text="{Binding ScheduleLinkClipboardText}" VerticalAlignment="Center" Margin="0,0,14,0" />
                                            <TextBlock Text="Project start" VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <DatePicker SelectedDate="{Binding ScheduleProjectStartDate, Mode=TwoWay}" Margin="0,2,10,2" Width="120" />
                                            <TextBlock Text="Must finish by" VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <DatePicker SelectedDate="{Binding ScheduleMustFinishByDate, Mode=TwoWay}" Margin="0,2,14,2" Width="120" />
                                            <TextBlock Text="Baseline" VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <ComboBox ItemsSource="{Binding ScheduleBaselineNames}" SelectedItem="{Binding ActiveScheduleBaselineName, Mode=TwoWay}" Width="130" Margin="0,2,6,2" />
                                            <TextBox x:Name="BaselineNameTextBox" Width="110" Margin="0,2,4,2" VerticalContentAlignment="Center" ToolTip="Name for a new baseline capture" />
                                            <Button Content="Capture" Padding="8,3" Margin="0,2,4,2" Click="ScheduleCaptureBaseline_Click" ToolTip="Snapshot current dates into the named baseline" />
                                             <Button Content="Delete baseline" Padding="8,3" Margin="0,2,14,2" Click="ScheduleDeleteBaseline_Click" />
                                             <ComboBox ItemsSource="{x:Static vm:MainWindowViewModel.ScheduleEditModeOptions}"
                                                       SelectedItem="{Binding ScheduleEditMode, Mode=TwoWay}"
                                                       Width="150"
                                                       Margin="0,2,6,2" />
                                             <CheckBox Content="Compare baseline"
                                                       IsChecked="{Binding ShowScheduleBaselineComparison, Mode=TwoWay}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,2,6,2" />
                                             <Button Content="Pop out comparison" Padding="8,3" Margin="0,2,14,2" Click="SchedulePopoutComparison_Click" />
                                             <Button Content="Calendars..." Padding="8,3" Margin="0,2,14,2" Click="ScheduleCalendars_Click" />
                                             <TextBlock Text="Progress" VerticalAlignment="Center" Margin="0,0,4,0" />
                                             <Button Content="0%" Padding="7,3" Margin="0,2,2,2" Click="ScheduleProgress0_Click" />
                                             <Button Content="25%" Padding="7,3" Margin="0,2,2,2" Click="ScheduleProgress25_Click" />
                                             <Button Content="50%" Padding="7,3" Margin="0,2,2,2" Click="ScheduleProgress50_Click" />
                                             <Button Content="75%" Padding="7,3" Margin="0,2,2,2" Click="ScheduleProgress75_Click" />
                                             <Button Content="100%" Padding="7,3" Margin="0,2,14,2" Click="ScheduleProgress100_Click" />
                                            <TextBlock Text="Zoom" VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <Button Content="Day" Padding="8,3" Margin="0,2,3,2" Click="GanttZoomDay_Click" />
                                            <Button Content="Week" Padding="8,3" Margin="0,2,3,2" Click="GanttZoomWeek_Click" />
                                             <Button Content="Month" Padding="8,3" Margin="0,2,3,2" Click="GanttZoomMonth_Click" />
                                             <TextBlock Text="{Binding ScheduleHealthText}" VerticalAlignment="Center" Margin="14,0,0,0" />
                                        </WrapPanel>
                                    </Border>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="11*" MinWidth="320" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="9*" MinWidth="260" />
                                        </Grid.ColumnDefinitions>
                                        <DataGrid x:Name="ScheduleGrid"
                                                  Grid.Column="0"
                                                  ItemsSource="{Binding ScheduleActivities}"
                                                  SelectedItem="{Binding SelectedScheduleActivity, Mode=TwoWay}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserSortColumns="False"
                                                  IsReadOnly="False"
                                                  SelectionMode="Extended"
                                                  SelectionUnit="FullRow"
                                                  RowHeight="26"
                                                  ColumnHeaderHeight="48"
                                                  EnableRowVirtualization="False"
                                                  ScrollViewer.CanContentScroll="False"
                                                  Loaded="ScheduleGrid_Loaded"
                                                  BeginningEdit="ScheduleGrid_BeginningEdit"
                                                  PreviewMouseLeftButtonDown="ScheduleGrid_PreviewMouseLeftButtonDown"
                                                  PreviewMouseRightButtonUp="ScheduleGrid_PreviewMouseRightButtonUp"
                                                  SelectionChanged="ScheduleGrid_SelectionChanged">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHeading}" Value="True">
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                            <Setter Property="Background" Value="#EDF2F7" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsHammock}" Value="True">
                                                            <Setter Property="Foreground" Value="#0F766E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto" />
                                                <DataGridTemplateColumn Header="Activity name" SortMemberPath="Name" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" Margin="{Binding OutlineLevel, Converter={StaticResource OutlineIndent}}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Type" SortMemberPath="Kind" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Kind}" VerticalAlignment="Center" Margin="4,0" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{x:Static vm:MainWindowViewModel.ScheduleKindOptions}" SelectedItem="{Binding Kind, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Dur" Binding="{Binding DurationDays}" Width="Auto" />
                                                <DataGridTemplateColumn Header="Calendar" SortMemberPath="CalendarId" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding DataContext.ScheduleCalendars, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      DisplayMemberPath="Name"
                                                                      SelectedValuePath="Id"
                                                                      SelectedValue="{Binding CalendarId, Mode=OneWay}"
                                                                      IsHitTestVisible="False"
                                                                      Focusable="False"
                                                                      BorderThickness="0"
                                                                      Background="Transparent" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding DataContext.ScheduleCalendars, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      DisplayMemberPath="Name"
                                                                      SelectedValuePath="Id"
                                                                      SelectedValue="{Binding CalendarId, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Start" Binding="{Binding EarlyStart, Converter={StaticResource DateOnlyText}}" IsReadOnly="True" Width="Auto" />
                                                <DataGridTextColumn Header="Finish" Binding="{Binding EarlyFinish, Converter={StaticResource DateOnlyText}}" IsReadOnly="True" Width="Auto" />
                                                <DataGridTextColumn Header="Late start" Binding="{Binding LateStart, Converter={StaticResource DateOnlyText}}" IsReadOnly="True" Width="Auto" />
                                                <DataGridTextColumn Header="Late finish" Binding="{Binding LateFinish, Converter={StaticResource DateOnlyText}}" IsReadOnly="True" Width="Auto" />
                                                <DataGridTextColumn Header="Float" Binding="{Binding TotalFloatDays}" IsReadOnly="True" Width="Auto" />
                                                <DataGridTextColumn Header="Slip" Binding="{Binding SlipDays}" IsReadOnly="True" Width="Auto" />
                                                <DataGridTemplateColumn Header="Constraint" SortMemberPath="ConstraintType" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ConstraintType}" VerticalAlignment="Center" Margin="4,0" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{x:Static vm:MainWindowViewModel.ScheduleConstraintOptions}" SelectedItem="{Binding ConstraintType, UpdateSourceTrigger=PropertyChanged}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Constraint date" Binding="{Binding ConstraintDate, Converter={StaticResource DateOnlyText}}" Width="Auto" />
                                                <DataGridTextColumn Header="Predecessors" Binding="{Binding PredecessorText}" Width="Auto" />
                                                <DataGridTextColumn Header="Members" Binding="{Binding HammockMemberText}" Width="Auto" />
                                                 <DataGridTextColumn Header="BL start" Binding="{Binding BaselineStart, Converter={StaticResource DateOnlyText}, UpdateSourceTrigger=LostFocus}" Width="Auto" />
                                                 <DataGridTextColumn Header="BL finish" Binding="{Binding BaselineFinish, Converter={StaticResource DateOnlyText}, UpdateSourceTrigger=LostFocus}" Width="Auto" />
                                                <DataGridTextColumn Header="%" Binding="{Binding PercentComplete}" Width="Auto" />
                                                <DataGridTextColumn Header="Note" Binding="{Binding ScheduleNote}" IsReadOnly="True" Width="Auto" MinWidth="90" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />
                                        <Border Grid.Column="2" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" CornerRadius="8" Background="White" ClipToBounds="True">
                                            <DockPanel LastChildFill="True">
                                                <ScrollViewer x:Name="GanttHeaderScroll" DockPanel.Dock="Top" Height="48" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Focusable="False">
                                                    <Canvas x:Name="GanttHeaderCanvas" Height="48" HorizontalAlignment="Left" VerticalAlignment="Top" />
                                                </ScrollViewer>
                                                <ScrollViewer x:Name="GanttBodyScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ScrollChanged="GanttBodyScroll_ScrollChanged">
                                                     <Canvas x:Name="GanttBodyCanvas"
                                                             HorizontalAlignment="Left"
                                                             VerticalAlignment="Top"
                                                             Background="White"
                                                             PreviewMouseRightButtonUp="GanttBodyCanvas_PreviewMouseRightButtonUp"
                                                             MouseLeftButtonDown="GanttBodyCanvas_MouseLeftButtonDown"
                                                             MouseMove="GanttBodyCanvas_MouseMove"
                                                             MouseLeftButtonUp="GanttBodyCanvas_MouseLeftButtonUp" />
                                                </ScrollViewer>
                                            </DockPanel>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                    </DockPanel>
                </Border>

                <GridSplitter x:Name="WorkspaceGridSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" />

                <Border x:Name="DetailWorkspaceShell" Grid.Column="2" Background="#F8FAFD" BorderBrush="#DCE4EE" BorderThickness="1" CornerRadius="14" Padding="8" ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="DetailWorkspaceContentColumn" Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="DetailWorkspacePanel" Grid.Column="0" Background="White" BorderBrush="#DCE4EE" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,8,0" ClipToBounds="True">
                            <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" Background="#EEF4FF" CornerRadius="9" Margin="0,0,9,0">
                                        <Image Source="/Assets/Icons/png/ic_tab_resources_16.png" Width="18" Height="18" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Resource Drilldown" FontSize="16" FontWeight="Bold" Foreground="#111827" />
                                        <TextBlock Text="{Binding LedgerTitle}" Foreground="#71809A" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="×"
                                        Width="28"
                                        Height="28"
                                        MinWidth="0"
                                        Padding="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        FontSize="18"
                                        Margin="8,0,0,0"
                                        ToolTip="Hide resource drilldown"
                                        Click="HideDetailWorkspacePanel_Click" />
                            </Grid>
                            <UniformGrid Columns="2" Margin="0,12,0,10">
                                <Border Background="#FBFCFE" BorderBrush="#E1E7F0" BorderThickness="1" Padding="12" Margin="0,0,6,6" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Transactions" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding LedgerTransactionCount}" FontSize="18" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FBFCFE" BorderBrush="#E1E7F0" BorderThickness="1" Padding="12" Margin="0,0,0,6" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Raw total" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding LedgerTransactionTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" FontSize="18" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FBFCFE" BorderBrush="#E1E7F0" BorderThickness="1" Padding="12" Margin="0,0,6,0" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Units" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding LedgerUnitsTotal, StringFormat={}{0:N2}}" FontSize="18" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FBFCFE" BorderBrush="#E1E7F0" BorderThickness="1" Padding="12" Margin="0" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Average rate" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="{Binding LedgerAverageRate, Converter={StaticResource AccountingNoDecimalsConverter}, ConverterParameter=Decimals:2}" FontSize="18" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <TabControl x:Name="LedgerWorkspaceTabControl"
                                    PreviewMouseLeftButtonDown="WorkspaceTabs_PreviewMouseLeftButtonDown"
                                    PreviewMouseMove="WorkspaceTabs_PreviewMouseMove"
                                    PreviewMouseLeftButtonUp="WorkspaceTabs_PreviewMouseLeftButtonUp"
                                    SelectionChanged="LedgerWorkspaceTabControl_SelectionChanged">
                            <TabItem Header="Costs into this resource">
                                <DockPanel LastChildFill="True">
                                    <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource DetailWorkspaceViewStripTemplate}" />
                                    <Grid>
                                        <DataGrid x:Name="LedgerTransactionsGrid"
                                                  ItemsSource="{Binding LedgerTransactionsView}"
                                                  IsReadOnly="True"
                                                  Sorting="ColumnHighlightGrid_Sorting">
                                            <DataGrid.Style>
                                                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowLedgerCostsPivotByMonth}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Style>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Row" Binding="{Binding RowNumber}" Width="55" />
                                                <DataGridTextColumn Header="FY" Binding="{Binding FyPeriod}" Width="55" />
                                                <DataGridTextColumn Header="Task" Binding="{Binding TaskNumber}" Width="110" />
                                                <DataGridTextColumn Header="Period" Binding="{Binding Period}" Width="60" />
                                                <DataGridTextColumn Header="Date" Binding="{Binding DocDate}" Width="90" />
                                                <DataGridTextColumn Header="Units" Binding="{Binding Units, StringFormat={}{0:N2}}" Width="70" />
                                                <DataGridTextColumn Header="Rate" Binding="{Binding UnitRate, Converter={StaticResource AccountingNoDecimalsConverter}, ConverterParameter=Decimals:2}" Width="80" />
                                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, Converter={StaticResource AccountingNoDecimalsConverter}}" Width="85" />
                                                <DataGridTextColumn Header="Cost Ledger" Binding="{Binding CostLedger}" Width="90" />
                                                <DataGridTextColumn Header="Cost Account" Binding="{Binding CostAccount}" Width="95" />
                                                <DataGridTextColumn Header="Project" Binding="{Binding ProjectCode}" Width="80" />
                                                <DataGridTextColumn Header="Parent Project" Binding="{Binding ParentProjectCode}" Width="100" />
                                                <DataGridTextColumn Header="Resource Code" Binding="{Binding ResourceCode}" Width="95" />
                                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="60" />
                                                <DataGridTextColumn Header="Resource Desc" Binding="{Binding ResourceDescription}" Width="160" />
                                                <DataGridTextColumn Header="Selected Resource" Binding="{Binding LedgerResourceName}" Width="160" />
                                                <DataGridTextColumn Header="PO Number" Binding="{Binding PoNumber}" Width="95" />
                                                <DataGridTextColumn Header="PO Comments" Binding="{Binding PoComments}" Width="140" />
                                                <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierName}" Width="150" />
                                                <DataGridTextColumn Header="Narrative 1" Binding="{Binding Narrative1}" Width="180" />
                                                <DataGridTextColumn Header="Narrative 2" Binding="{Binding Narrative2}" Width="180" />
                                                <DataGridTextColumn Header="Narrative 3" Binding="{Binding Narrative3}" Width="160" />
                                                <DataGridTextColumn Header="Who" Binding="{Binding Who}" Width="140" />
                                                <DataGridTextColumn Header="ECM Number" Binding="{Binding EcmNumber}" Width="120" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <DataGrid x:Name="LedgerMonthlyPivotGrid"
                                                  ItemsSource="{Binding LedgerMonthlyPivotRows}"
                                                  Sorting="ColumnHighlightGrid_Sorting">
                                            <DataGrid.Style>
                                                <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowLedgerCostsPivotByMonth}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.Style>
                                        </DataGrid>
                                    </Grid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="Monthly forecast">
                                <DockPanel LastChildFill="True">
                                    <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource DetailWorkspaceViewStripTemplate}" />
                                    <DataGrid x:Name="SelectedMonthlyForecastsGrid"
                                              ItemsSource="{Binding SelectedMonthlyForecasts}"
                                              IsReadOnly="False"
                                              Sorting="ColumnHighlightGrid_Sorting"
                                              PreviewMouseRightButtonUp="SelectedMonthlyForecastsGrid_PreviewMouseRightButtonUp"
                                              BeginningEdit="SelectedMonthlyForecastsGrid_BeginningEdit">
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter Property="Background" Value="#F3F4F6" />
                                                        <Setter Property="Foreground" Value="#94A3B8" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.CellStyle>
                                    </DataGrid>
                                </DockPanel>
                            </TabItem>

                            <TabItem Header="Spend curve">
                                <DockPanel LastChildFill="False" Margin="6">
                                    <ContentControl DockPanel.Dock="Top" Content="{Binding}" ContentTemplate="{StaticResource DetailWorkspaceViewStripTemplate}" />
                                    <UniformGrid DockPanel.Dock="Top" Columns="2" Margin="0,0,0,10">
                                        <Border BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Padding="10" Margin="0,0,6,0" CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Text="Spend to date" Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding LedgerTransactionTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" FontSize="18" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" Padding="10" Margin="0" CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Text="Spend + forecast" Foreground="{StaticResource MutedTextBrush}" />
                                                <TextBlock Text="{Binding LedgerProjectedTotal, Converter={StaticResource AccountingNoDecimalsConverter}}" FontSize="18" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <Rectangle Width="18" Height="3" Fill="#1D4ED8" VerticalAlignment="Center" />
                                            <TextBlock Text="  Spend to date" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Canvas Width="18" Height="8" VerticalAlignment="Center">
                                                <Line X1="0" Y1="4" X2="18" Y2="4" Stroke="#0F766E" StrokeThickness="3" StrokeDashArray="4 3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                            </Canvas>
                                            <TextBlock Text="  Spend + forecast" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Text="View" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="24,0,6,0" />
                                        <ComboBox ItemsSource="{Binding LedgerChartRangeOptions}"
                                                  SelectedItem="{Binding SelectedLedgerChartRangeOption}"
                                                  DisplayMemberPath="Name"
                                                  Width="145"
                                                  Height="28" />
                                    </StackPanel>

                                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource SoftBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                                        <Grid Height="300" ClipToBounds="True">
                                            <ScrollViewer x:Name="LedgerChartScrollViewer"
                                                          HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          CanContentScroll="False"
                                                          PreviewMouseRightButtonDown="LedgerChartScrollViewer_PreviewMouseRightButtonDown"
                                                          PreviewMouseMove="LedgerChartScrollViewer_PreviewMouseMove"
                                                          PreviewMouseRightButtonUp="LedgerChartScrollViewer_PreviewMouseRightButtonUp">
                                                <Grid Width="{Binding LedgerChartCanvasWidth}" Height="300">
                                                    <Canvas Width="{Binding LedgerChartCanvasWidth}" Height="300">
                                                        <ItemsControl ItemsSource="{Binding LedgerChartGridLines}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <Canvas Width="{Binding LedgerChartCanvasWidth}" Height="300" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" Stroke="#E5E7EB" StrokeThickness="1" SnapsToDevicePixels="True" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <Path Data="{Binding LedgerActualChartGeometry}" Stroke="#1D4ED8" StrokeThickness="3" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}" />
                                                        <Path Data="{Binding LedgerForecastChartGeometry}" Stroke="#0F766E" StrokeThickness="3" StrokeDashArray="4 3" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="{x:Null}" />

                                                        <ItemsControl ItemsSource="{Binding LedgerChartXAxisLabels}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <Canvas Width="{Binding LedgerChartCanvasWidth}" Height="300" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemContainerStyle>
                                                                <Style TargetType="ContentPresenter">
                                                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                                </Style>
                                                            </ItemsControl.ItemContainerStyle>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Text}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Canvas>
                                                </Grid>
                                            </ScrollViewer>

                                            <Border Width="58"
                                                    HorizontalAlignment="Left"
                                                    Background="White"
                                                    IsHitTestVisible="False"
                                                    Panel.ZIndex="20">
                                                <ItemsControl ItemsSource="{Binding LedgerChartYAxisLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas Width="58" Height="300" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <TextBlock DockPanel.Dock="Top" Text="{Binding LedgerChartStatusText}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                                </DockPanel>
                            </TabItem>
                        </TabControl>
                            </DockPanel>
                        </Border>

                        <Border x:Name="DetailWorkspaceRail"
                                Grid.Column="1"
                                Width="52"
                                Margin="8,0,0,0"
                                VerticalAlignment="Stretch"
                                Background="#FCFCFD"
                                BorderBrush="{StaticResource SoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="5">
                            <Button x:Name="DetailWorkspaceCollapsedTab"
                                    Click="DetailWorkspaceCollapsedTab_Click"
                                    ToolTip="Show resource drilldown"
                                    Background="#F8FAFC"
                                    BorderBrush="#D7E0EA"
                                    BorderThickness="1"
                                    Foreground="#475569"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Width="32"
                                    Height="90"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="16"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="Details" FontSize="14">
                                    <TextBlock.LayoutTransform>
                                        <RotateTransform Angle="-90" />
                                    </TextBlock.LayoutTransform>
                                </TextBlock>
                            </Button>
                        </Border>
                    </Grid>
                </Border>
                <Border x:Name="CollapsedDetailWorkspaceHost"
                        Grid.Column="2"
                        Width="40"
                        Visibility="Collapsed"
                        Background="Transparent">
                    <Button x:Name="CollapsedDetailWorkspaceButton"
                            Click="DetailWorkspaceCollapsedTab_Click"
                            ToolTip="Show resource drilldown"
                            Background="#F8FAFC"
                            BorderBrush="#D7E0EA"
                            BorderThickness="1"
                            Foreground="#475569"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Width="32"
                            Height="90"
                            Padding="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="16"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="Details" FontSize="14">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90" />
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                    </Button>
                </Border>
            </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
