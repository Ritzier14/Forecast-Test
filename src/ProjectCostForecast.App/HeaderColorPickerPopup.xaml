<UserControl x:Class="ProjectCostForecast.App.HeaderColorPickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="520"
             Height="420"
             Background="Transparent"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <Border Background="White"
            BorderBrush="#DCE4EE"
            BorderThickness="1"
            CornerRadius="16"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Width="34"
                        Height="34"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#334155"
                        FontSize="18"
                        Content="X" />
            </Grid>

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#DCE4EE"
                    BorderThickness="1"
                    CornerRadius="12"
                    Height="44"
                    Margin="0,0,0,14">
                <Border x:Name="PreviewBorder"
                        Margin="1"
                        CornerRadius="11" />
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,0,0,14">
                <Button x:Name="DefaultTabButton"
                        Click="DefaultTabButton_Click"
                        Padding="10,6"
                        Margin="0,0,12,0"
                        Background="Transparent"
                        BorderThickness="0,0,0,3"
                        BorderBrush="#2563EB"
                        Foreground="#2563EB"
                        FontWeight="SemiBold"
                        Content="Default colours" />
                <Button x:Name="CustomTabButton"
                        Click="CustomTabButton_Click"
                        Padding="10,6"
                        Background="Transparent"
                        BorderThickness="0,0,0,3"
                        BorderBrush="Transparent"
                        Foreground="#475569"
                        Content="Custom" />
            </StackPanel>

            <Grid Grid.Row="3">
                <Grid x:Name="DefaultTabContent">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="DefaultSwatchPanel" />
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="CustomTabContent"
                      Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,12">
                        <TextBlock Text="Base colour"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32"
                                    Height="32"
                                    BorderBrush="#CBD5E1"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,0,10,0">
                                <Border x:Name="CustomColourPreview"
                                        CornerRadius="7" />
                            </Border>
                            <TextBox x:Name="CustomHexTextBox"
                                     Width="140"
                                     Height="32"
                                     VerticalContentAlignment="Center"
                                     TextChanged="CustomHexTextBox_TextChanged" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Margin="0,0,0,12">
                        <TextBlock Text="Colour well"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,0,0,6" />
                        <WrapPanel x:Name="CustomColourWellPanel" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Margin="0,0,0,12">
                        <TextBlock Text="Gradient"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,0,0,6" />
                        <WrapPanel x:Name="GradientVariantPanel" />
                    </StackPanel>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button x:Name="ResetButton"
                        Click="ResetButton_Click"
                        Padding="12,6"
                        Margin="0,0,10,0"
                        Content="Default" />
                <Button x:Name="ApplyButton"
                        Click="ApplyButton_Click"
                        Padding="16,6"
                        Content="Apply" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
